## govee2mqtt environment configuration
## Copy this to .env and fill in your values:
##   cp .env.example .env

## ─── MQTT Broker ───────────────────────────────────────────────
## Required. The MQTT broker that Home Assistant is connected to.
GOVEE_MQTT_HOST=localhost
GOVEE_MQTT_PORT=1883
# GOVEE_MQTT_USER=
# GOVEE_MQTT_PASSWORD=

## ─── Govee Cloud APIs ──────────────────────────────────────────
## Optional. Enables Platform API features (scenes, device metadata).
## Get a key at: https://developer.govee.com/reference/apply-you-govee-api-key
# GOVEE_API_KEY=

## Optional. Enables undocumented IoT API (low-latency status, one-click scenes).
# GOVEE_EMAIL=
# GOVEE_PASSWORD=

## ─── Temperature ───────────────────────────────────────────────
## "C" for Celsius (default) or "F" for Fahrenheit.
# GOVEE_TEMPERATURE_SCALE=C

## ─── LAN Discovery ─────────────────────────────────────────────
## Tune LAN device discovery. Usually not needed.
# GOVEE_LAN_NO_MULTICAST=false
# GOVEE_LAN_BROADCAST_ALL=false
# GOVEE_LAN_BROADCAST_GLOBAL=false
# GOVEE_LAN_SCAN=10.0.0.1,10.0.0.2
# GOVEE_LAN_LISTEN_PORT=4002
# GOVEE_LAN_DISCO_TIMEOUT=10

## ─── Effects / Scenes ──────────────────────────────────────────
## Disable effects in MQTT discovery (fixes Google Home offline issue).
# GOVEE_DISABLE_EFFECTS=false
## Comma-separated whitelist of effect names to include (case-insensitive).
# GOVEE_ALLOWED_EFFECTS=

## ─── Advanced ──────────────────────────────────────────────────
## Rust log filter. Examples: govee=info, govee=debug, govee=trace
# RUST_LOG=govee=info
## Log sensitive data (API tokens, passwords) — for debugging only!
# GOVEE_LOG_SENSITIVE_DATA=false
## Override the cache directory (default: XDG_CACHE_HOME or current dir)
# GOVEE_CACHE_DIR=
## Restrict Web UI to HA ingress proxy IP only (addon use)
# GOVEE_HTTP_INGRESS_ONLY=false
## Require this token for HTTP API access (Bearer header or ?token= query param).
## The /api/health endpoint is always accessible without auth.
# GOVEE_HTTP_AUTH_TOKEN=
